# Docling Conversion Service Configuration
# Copy this file to .env and update values for your environment

# Database Configuration
# SQLite database URL (directory will be created if it doesn't exist)
DATABASE_URL=sqlite:///./data/conversion_service.db

# S3 Configuration
# AWS S3 bucket for storing conversion artifacts
S3_BUCKET_NAME=aizk-conversion
S3_REGION=us-east-1

# AWS credentials (set in environment or use AWS profile)
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key

# For local S3-compatible storage (e.g., MinIO), set endpoint
# S3_ENDPOINT_URL=http://localhost:9000

# KaraKeep Client Configuration (optional, for fetching metadata)
# KARAKEEP_API_URL=http://localhost:8001
# KARAKEEP_API_KEY=your-api-key

# Worker Configuration
# Number of concurrent Docling conversion workers
WORKER_CONCURRENCY=4

# Fetch timeout in seconds (for HTTP requests to fetch bookmarks)
FETCH_TIMEOUT_SECONDS=30

# Size limits
# Maximum size for HTML content (bytes)
FETCH_MAX_SIZE_HTML=52428800

# Maximum size for PDF content (bytes)
FETCH_MAX_SIZE_PDF=104857600

# Temporary workspace for conversions (directory will be created if needed)
TEMP_WORKSPACE_PATH=./data/workspace

# API Configuration
# Host and port for FastAPI server
API_HOST=127.0.0.1
API_PORT=8000

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
