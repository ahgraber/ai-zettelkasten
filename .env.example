# Docling Conversion Service Configuration
# Copy this file to .env and update values for your environment.

# --- LLM API settings ---
# # Set default API keys here using nonstandard (underscore-prefixed) variable names
# # to prevent unintentional access.
# _ANTHROPIC_BASE_URL="https://api.anthropic.com/v1"
# _ANTHROPIC_API_KEY=""
# _GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
# _GEMINI_API_KEY=""
# _OPENAI_BASE_URL="https://api.openai.com/v1"
# _OPENAI_API_KEY=""
# _OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# _OPENROUTER_API_KEY=""

# # Select which LLM API to use for chat completions
# CHAT_COMPLETIONS_BASE_URL="${_OPENROUTER_BASE_URL}"
# CHAT_COMPLETIONS_API_KEY="${_OPENROUTER_API_KEY}"

# --- KaraKeep ---
# KaraKeep is the authoritative store for raw bookmark content.
# Both variables are required; the service will not start without them.
AIZK_FETCHER__KARAKEEP__BASE_URL="http://localhost:8001"
AIZK_FETCHER__KARAKEEP__API_KEY="your-api-key"

# --- Core ---
# SQLite database URL. The directory is created automatically if it does not exist.
DATABASE_URL="sqlite:///./data/conversion_service.db"

# --- S3 ---
# S3 bucket used to store conversion artifacts (Markdown, figures, manifest).
S3_BUCKET_NAME="aizk"
S3_REGION="us-east-1"
# AWS credentials. Omit to use the default credential chain (env, profile, IAM role).
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# For local S3-compatible storage (e.g. MinIO), set the endpoint URL.
# S3_ENDPOINT_URL="http://localhost:9000"

# --- Litestream ---
# Litestream replicates the SQLite database to S3 for durability.
LITESTREAM_ENABLED=true
# LITESTREAM_START_ROLE=api
# LITESTREAM_BINARY=litestream
# LITESTREAM_CONFIG_PATH=./data/litestream.yaml
# LITESTREAM_S3_BUCKET_NAME=aizk
# LITESTREAM_S3_PREFIX=db
LITESTREAM_S3_FORCE_PATH_STYLE=true
LITESTREAM_S3_SIGN_PAYLOAD=true
# LITESTREAM_RESTORE_ON_STARTUP=true
# LITESTREAM_ALLOW_EMPTY_RESTORE=true


# --- Worker ---
# Number of parallel conversion worker threads.
WORKER_CONCURRENCY=4
# Maximum conversion subprocesses that may use the GPU simultaneously.
# Prevents GPU memory exhaustion when multiple jobs are in the conversion phase.
WORKER_GPU_CONCURRENCY=1
# Maximum number of jobs that may be queued before submissions are rejected.
QUEUE_MAX_DEPTH=1000
# Seconds a failed job waits before becoming eligible for retry.
QUEUE_RETRY_AFTER_SECONDS=30
# Timeout in seconds for HTTP requests that fetch bookmark content from KaraKeep.
FETCH_TIMEOUT_SECONDS=30
# Maximum number of retry attempts before a job is permanently failed.
RETRY_MAX_ATTEMPTS=3
# Base delay in seconds for exponential backoff between retry attempts.
RETRY_BASE_DELAY_SECONDS=60
# Minutes after which an in-progress job is considered stale and reset.
WORKER_STALE_JOB_MINUTES=30
# Hard timeout in seconds for a single conversion job end-to-end.
WORKER_JOB_TIMEOUT_SECONDS=7200
# Seconds to wait for in-progress jobs to finish during graceful shutdown.
WORKER_DRAIN_TIMEOUT_SECONDS=300

# --- Docling Pipeline ---
# Maximum number of PDF pages to process per document.
AIZK_CONVERTER__DOCLING__PDF_MAX_PAGES=250
# Enable EasyOCR for text extraction from scanned pages.
AIZK_CONVERTER__DOCLING__OCR_ENABLED=true
# Enable TableFormer table structure extraction.
AIZK_CONVERTER__DOCLING__TABLE_STRUCTURE_ENABLED=true

# --- Docling Picture Description ---
# Enables AI-generated descriptions for figures, charts, and table images in PDFs.
# Requires an OpenAI-compatible chat completions endpoint (commercial or local).
# If BASE_URL or API_KEY is not set, picture description is disabled.
#
# Provider examples:
#
#   OpenRouter (commercial — many models available):
#     AIZK_CONVERTER__DOCLING__PICTURE_DESCRIPTION_BASE_URL="https://openrouter.ai/api/v1"
#     AIZK_CONVERTER__DOCLING__PICTURE_DESCRIPTION_API_KEY="sk-or-..."
#     AIZK_CONVERTER__DOCLING__PICTURE_DESCRIPTION_MODEL="openai/gpt-4.1-nano"
#
#   Local vLLM (run separately; no API key required):
#     AIZK_CONVERTER__DOCLING__PICTURE_DESCRIPTION_BASE_URL="http://localhost:8000/v1"
#     AIZK_CONVERTER__DOCLING__PICTURE_DESCRIPTION_API_KEY="unused"
#     AIZK_CONVERTER__DOCLING__PICTURE_DESCRIPTION_MODEL="ibm-granite/granite-4.0-3b-vision"
#
AIZK_CONVERTER__DOCLING__PICTURE_DESCRIPTION_BASE_URL=
AIZK_CONVERTER__DOCLING__PICTURE_DESCRIPTION_API_KEY=
AIZK_CONVERTER__DOCLING__PICTURE_DESCRIPTION_MODEL="openai/gpt-5.4-nano"
# Timeout in seconds for each VLM API call during picture description.
AIZK_CONVERTER__DOCLING__PICTURE_TIMEOUT=180
# Enable DocumentFigureClassifier and task-tagged prompting (chart2summary, tables_html).
# Requires picture description to be configured above.
AIZK_CONVERTER__DOCLING__PICTURE_CLASSIFICATION_ENABLED=true

# --- API Server ---
API_HOST=127.0.0.1
API_PORT=8000
# Enable auto-reload for local development (do not use in production).
# API_RELOAD=false

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Log format: json (structured, for production) or text (human-readable, for development)
LOG_FORMAT=json

# --- Observability ---
# MLflow experiment tracking for LLM tracing (optional).
MLFLOW_TRACING_ENABLED=false
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_EXPERIMENT_NAME=aizk-conversion
