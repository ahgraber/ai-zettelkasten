# Docling Conversion Service Configuration
# Copy this file to .env and update values for your environment

# Database Configuration
# SQLite database URL (directory will be created if it doesn't exist)
DATABASE_URL=sqlite:///./data/conversion_service.db

# S3 Configuration
# AWS S3 bucket for storing conversion artifacts
S3_BUCKET_NAME=aizk
S3_REGION=us-east-1

# AWS credentials (set in environment or use AWS profile)
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key

# For local S3-compatible storage (e.g., MinIO), set endpoint
# S3_ENDPOINT_URL=http://localhost:9000

# KaraKeep Client Configuration (optional, for fetching metadata)
# KARAKEEP_API_URL=http://localhost:8001
# KARAKEEP_API_KEY=your-api-key

# Worker Configuration
# Number of concurrent Docling conversion workers
WORKER_CONCURRENCY=4

# Fetch timeout in seconds (for HTTP requests to fetch bookmarks)
FETCH_TIMEOUT_SECONDS=30

# Docling parameters
DOCLING_VLM_MODEL="openai/gpt-5-nano"

# API Configuration
# Host and port for FastAPI server
API_HOST=127.0.0.1
API_PORT=8000

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Litestream Configuration (SQLite replication to S3)
LITESTREAM_ENABLED=true
# LITESTREAM_START_ROLE=api
# LITESTREAM_BINARY=litestream
# LITESTREAM_CONFIG_PATH=./data/litestream.yaml
# LITESTREAM_S3_BUCKET_NAME=aizk
# LITESTREAM_S3_PREFIX=db
LITESTREAM_S3_FORCE_PATH_STYLE=true
LITESTREAM_S3_SIGN_PAYLOAD=true
# LITESTREAM_RESTORE_ON_STARTUP=true
# LITESTREAM_ALLOW_EMPTY_RESTORE=true

### LLM API settings
# Set default API keys here using nonstandard (underscore-prefixed) variable names
# to prevent unintentional access.
_ANTHROPIC_BASE_URL="https://api.anthropic.com/v1"
_ANTHROPIC_API_KEY=""
_GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
_GEMINI_API_KEY=""
_OPENAI_BASE_URL="https://api.openai.com/v1"
_OPENAI_API_KEY=""
_OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
_OPENROUTER_API_KEY=""

# Select which LLM API to use for chat completions
CHAT_COMPLETIONS_BASE_URL="${_OPENROUTER_BASE_URL}"
CHAT_COMPLETIONS_API_KEY="${_OPENROUTER_API_KEY}"

# MLflow tracing (optional)
MLFLOW_TRACING_ENABLED=false
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_EXPERIMENT_NAME=aizk-conversion
