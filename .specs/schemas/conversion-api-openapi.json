    "/v1/bookmarks/{aizk_uuid}/outputs": {
      "get": {
        "tags": ["bookmarks"],
        "summary": "Get Bookmark Outputs",
        "description": "Return conversion outputs for a bookmark ordered by creation time descending.\n\nPass ``?latest=true`` to receive only the most recently created output.",
        "operationId": "get_bookmark_outputs_v1_bookmarks__aizk_uuid__outputs_get",
        "parameters": [
          {
            "name": "aizk_uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Aizk Uuid"
            }
          },
          {
            "name": "latest",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false,
              "title": "Latest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/OutputResponse"
                  },
                  "title": "Response Get Bookmark Outputs V1 Bookmarks  Aizk Uuid  Outputs Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
