  "components": {
    "schemas": {
      "ArtifactSummary": {
        "properties": {
          "s3_prefix": {
            "type": "string",
            "title": "S3 Prefix"
          },
          "markdown_key": {
            "type": "string",
            "title": "Markdown Key"
          },
          "manifest_key": {
            "type": "string",
            "title": "Manifest Key"
          },
          "figure_count": {
            "type": "integer",
            "title": "Figure Count"
          }
        },
        "type": "object",
        "required": ["s3_prefix", "markdown_key", "manifest_key", "figure_count"],
        "title": "ArtifactSummary",
        "description": "Summary of conversion artifacts for completed jobs."
      },
      "Body_ui_job_actions_ui_jobs_actions_post": {
        "properties": {
          "action": {
            "type": "string",
            "title": "Action"
          },
          "job_ids": {
            "anyOf": [
              {
                "items": {
                  "type": "integer"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Job Ids"
          },
          "status": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Status"
          },
          "search": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Search"
          },
          "sort": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Sort",
            "default": "queued_at"
          },
          "direction": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Direction",
            "default": "desc"
          },
          "limit": {
            "type": "integer",
            "maximum": 200.0,
            "minimum": 1.0,
            "title": "Limit",
            "default": 50
          },
          "offset": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Offset",
            "default": 0
          }
        },
        "type": "object",
        "required": ["action"],
        "title": "Body_ui_job_actions_ui_jobs_actions_post"
      },
      "BulkActionResponse": {
        "properties": {
          "action": {
            "type": "string",
            "enum": ["retry", "cancel"],
            "title": "Action"
          },
          "results": {
            "items": {
              "$ref": "#/components/schemas/BulkActionResult"
            },
            "type": "array",
            "title": "Results"
          },
          "summary": {
            "$ref": "#/components/schemas/BulkActionSummary"
          }
        },
        "type": "object",
        "required": ["action", "results", "summary"],
        "title": "BulkActionResponse",
        "description": "Response schema for bulk job actions."
      },
      "BulkActionResult": {
        "properties": {
          "job_id": {
            "type": "integer",
            "title": "Job Id"
          },
          "status": {
            "type": "string",
            "enum": ["success", "error"],
            "title": "Status"
          },
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          }
        },
        "type": "object",
        "required": ["job_id", "status"],
        "title": "BulkActionResult",
        "description": "Per-job result for bulk actions."
      },
      "BulkActionSummary": {
        "properties": {
          "success": {
            "type": "integer",
            "title": "Success"
          },
          "errors": {
            "type": "integer",
            "title": "Errors"
          }
        },
        "type": "object",
        "required": ["success", "errors"],
        "title": "BulkActionSummary",
        "description": "Summary counts for bulk actions."
      },
      "BulkJobActionRequest": {
        "properties": {
          "action": {
            "type": "string",
            "enum": ["retry", "cancel"],
            "title": "Action"
          },
          "job_ids": {
            "items": {
              "type": "integer"
            },
            "type": "array",
            "maxItems": 100,
            "minItems": 1,
            "title": "Job Ids"
          }
        },
        "type": "object",
        "required": ["action", "job_ids"],
        "title": "BulkJobActionRequest",
        "description": "Request schema for bulk job actions."
      },
      "ConversionJobStatus": {
        "type": "string",
        "enum": [
          "NEW",
          "QUEUED",
          "RUNNING",
          "UPLOAD_PENDING",
          "SUCCEEDED",
          "FAILED_RETRYABLE",
          "FAILED_PERM",
          "CANCELLED"
        ],
        "title": "ConversionJobStatus",
        "description": "Allowed statuses for conversion jobs."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "JobList": {
        "properties": {
          "jobs": {
            "items": {
              "$ref": "#/components/schemas/JobResponse"
            },
            "type": "array",
            "title": "Jobs"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          },
          "limit": {
            "type": "integer",
            "title": "Limit"
          },
          "offset": {
            "type": "integer",
            "title": "Offset"
          }
        },
        "type": "object",
        "required": ["jobs", "total", "limit", "offset"],
        "title": "JobList",
        "description": "Response schema for job listing."
      },
      "JobResponse": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "aizk_uuid": {
            "type": "string",
            "format": "uuid",
            "title": "Aizk Uuid"
          },
          "karakeep_id": {
            "type": "string",
            "title": "Karakeep Id"
          },
          "url": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1,
                "format": "uri"
              },
              {
                "type": "null"
              }
            ],
            "title": "Url"
          },
          "title": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Title"
          },
          "source_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Type"
          },
          "status": {
            "$ref": "#/components/schemas/ConversionJobStatus"
          },
          "attempts": {
            "type": "integer",
            "title": "Attempts"
          },
          "payload_version": {
            "type": "integer",
            "title": "Payload Version"
          },
          "idempotency_key": {
            "type": "string",
            "title": "Idempotency Key"
          },
          "error_code": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Code"
          },
          "error_message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Message"
          },
          "earliest_next_attempt_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Earliest Next Attempt At"
          },
          "queued_at": {
            "anyOf": [
              {
                "type": "string",
